# Telegram
BOT_TOKEN=your_telegram_bot_token
CHANNEL_ID=@your_channel
GROUP_CHAT_ID=-1001234567890
ADMIN_IDS=123456789,987654321

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/botdb

# Redis
REDIS_URL=redis://localhost:6379/0

# CryptoRank
CRYPTORANK_API_KEY=your_cryptorank_key

# Twitter (optional)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# LLM Provider: "groq" or "openai"
LLM_PROVIDER=groq

# Groq (if provider = groq)
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama3-70b-8192

# OpenAI (if provider = openai)
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4

# Fallback if no API key
USE_LLAMA_FALLBACK=true

# Trigger settings
TRIGGER_PRICE_CHANGE_PERCENT=2.0
TRIGGER_TIMEFRAME_MINUTES=30

# Language
DEFAULT_LANGUAGE=ru

# MCP Server URL (for internal communication)
MCP_SERVER_URL=http://mcp-server:8001